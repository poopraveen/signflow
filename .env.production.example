# =============================================================================
# SignFlow — production / Vercel environment variables
# =============================================================================
# Copy each KEY into Vercel: Project → Settings → Environment Variables
# Use "Production" (and "Preview" if you want staging deploys to work the same).
# Never commit a file with real secrets; this file is safe to commit.
#
# Vercel sets NODE_ENV=production automatically — do not set it here.
# =============================================================================

# --- Auth.js / NextAuth (Google sign-in + API key pepper) ---------------------
# Generate: openssl rand -base64 32
AUTH_SECRET=replace-with-random-base64-string
# Google Cloud Console → OAuth 2.0 Client (Web)
# Authorized redirect URI: https://<YOUR_VERCEL_HOST>/api/auth/callback/google
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Required: MongoDB (Atlas recommended) -----------------------------------
# Network access: allow your Vercel region or 0.0.0.0/0 for development.
# Use the connection string that works from the public internet (SRV or standard).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority

# Optional — database name inside the cluster (default in app: signflow)
MONGODB_DB=signflow

# --- Required for correct invite links (native SignFlow send / emails) -------
# Public URL of this deployment, no trailing slash.
# Example: https://signflow.vercel.app  or https://sign.yourdomain.com
APP_ORIGIN=https://your-project.vercel.app

# --- Gmail (optional — without these, send may skip SMTP) --------------------
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
# GMAIL_FROM=SignFlow <you@gmail.com>

# --- Third-party DocuSign bridge API -----------------------------------------
# Random long secret; callers send header: x-integration-api-key: <same value>
INTEGRATION_API_KEY=generate-a-long-random-string

# --- DocuSign JWT (bridge + token refresh) -----------------------------------
# https://developers.docusign.com/platform/auth/jwt/
DOCUSIGN_INTEGRATION_KEY=your-integration-key-uuid
DOCUSIGN_USER_ID=impersonated-user-guid
# PEM as one line with \n escapes, OR base64 of the PEM file contents
DOCUSIGN_RSA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# Demo: account-d.docusign.com  |  Production: account.docusign.com
DOCUSIGN_OAUTH_BASE_PATH=account.docusign.com
# Optional if the user belongs to multiple DocuSign accounts
# DOCUSIGN_ACCOUNT_ID=

# --- DocuSign Connect webhook (optional) -------------------------------------
# Must match the HMAC secret in DocuSign Admin → Connect for your endpoint:
#   POST https://<APP_ORIGIN>/api/webhooks/docusign-connect
# DOCUSIGN_CONNECT_HMAC_SECRET=
