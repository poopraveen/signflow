# Local development — see .env.production.example for Vercel / production checklist.

# --- Auth (Google + sessions + API key hashing) --------------------------------
# Generate: openssl rand -base64 32
# AUTH_SECRET=
# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect: http://localhost:3000/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb://127.0.0.1:27017/signflow

# Optional database name (default: signflow)
# MONGODB_DB=signflow

# Public origin for invite links (required in production; optional locally)
# APP_ORIGIN=http://localhost:3000

# --- DocuSign eSignature (JWT) — https://developers.docusign.com ---
# Integration key (client ID) from your DocuSign app
# DOCUSIGN_INTEGRATION_KEY=
# API username GUID to impersonate (Settings → Apps and Keys → User ID)
# DOCUSIGN_USER_ID=
# RSA private key PEM for JWT (full PEM or base64 of PEM; newlines as \n)
# DOCUSIGN_RSA_PRIVATE_KEY=
# Demo: account-d.docusign.com | Production: account.docusign.com
# DOCUSIGN_OAUTH_BASE_PATH=account-d.docusign.com
# Optional: pin account if the user has several
# DOCUSIGN_ACCOUNT_ID=

# Secret the third-party system sends when calling your bridge API
# INTEGRATION_API_KEY=

# Optional: DocuSign Connect HMAC secret (must match Connect configuration)
# DOCUSIGN_CONNECT_HMAC_SECRET=

# --- Gmail (SMTP) — use an App Password, not your normal password ---
# https://myaccount.google.com/apppasswords (requires 2-Step Verification)
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Optional "From" display (defaults to GMAIL_USER)
# GMAIL_FROM="SignFlow <you@gmail.com>"

# --- OpenAI (optional — “Polish with AI” on new envelope) ----------------------
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# Optional model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
